# Copy to .env and fill in values before: docker compose up -d

DOKPLOY_URL=http://host.docker.internal:3000
DOKPLOY_WEBHOOK=http://host.docker.internal:3000/api/deploy/YOUR_DEPLOY_WEBHOOK_TOKEN
DOKPLOY_TOKEN=your-dokploy-api-token
DOKPLOY_APPLICATION_ID=your-dokploy-application-id

GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=your-github-pat

# Docker-in-Docker address on kestra-net (check with: docker inspect kestra-dind-1)
# Enable in Docker Desktop: Settings -> General -> Expose daemon on tcp://localhost:2375 without TLS
DOCKER_HOST=tcp://host.docker.internal:2375

# Pipeline push target (host Docker -> local registry port 5000)
REGISTRY=localhost:5000

# Dokploy app image URL on host (same registry, port published to host)
REGISTRY_HOST=172.26.48.1:5000

GIT_REPO=https://github.com/kirtiprasad2003/fastapi-minimal-poc.git
GIT_BRANCH=main

APP_HEALTH_URL=http://host.docker.internal:8000/health
