# OKE/Kaniko build — uses committed frontend/dist (build with npm run build before push).
# Multi-stage Node+Python fails on Kaniko after stage 0 deletes the filesystem.
FROM python:3.11-slim

WORKDIR /app

COPY backend/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/app ./app
COPY frontend/dist ./frontend/dist

ENV PYTHONUNBUFFERED=1
EXPOSE 3100
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "3100"]
